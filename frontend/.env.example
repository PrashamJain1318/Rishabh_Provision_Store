# -----------------------------------------------------------------------------
# Frontend Environment Variables (Vercel)
# -----------------------------------------------------------------------------

# Next.js Application URL
# Used for SEO metadata, OpenGraph, and internal absolute URLs
NEXT_PUBLIC_APP_URL="https://rishabh-provision-store.vercel.app"

# API Base URL (Backend Hosted on Railway/Render)
NEXT_PUBLIC_API_URL="https://api.rishabh-provision-store.com/api"

# WebSockets Server URL for Live Tracking
NEXT_PUBLIC_SOCKET_URL="https://api.rishabh-provision-store.com"

# Payment Gateways (Public Keys)
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_XXXXXXXXXXXX"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_XXXXXXXXXXXX"

# Google Maps API Key for Delivery Tracking & Location Services
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="AIzaSyXXXXXXXXXXXXXXXX"
