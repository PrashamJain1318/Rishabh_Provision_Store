# -----------------------------------------------------------------------------
# Backend Environment Variables (Railway / Render)
# -----------------------------------------------------------------------------

# Server Configuration
PORT=5001
NODE_ENV="production"
FRONTEND_URL="https://rishabh-provision-store.vercel.app"

# MongoDB Atlas Connection String
# IMPORTANT: Use the driver connection string format (mongodb+srv)
MONGO_URI="mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/rishabh_store?retryWrites=true&w=majority"

# Authentication Secrets
JWT_SECRET="generate-a-secure-random-32-byte-string-here"
JWT_EXPIRE="30d"

# Payment Gateways (Secret Keys - Never Expose to Frontend)
RAZORPAY_KEY_ID="rzp_test_XXXXXXXXXXXX"
RAZORPAY_KEY_SECRET="XXXXXXXXXXXXXXXX"
STRIPE_SECRET_KEY="sk_test_XXXXXXXXXXXX"

# Cloudinary Integration (Image Uploads)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Nodemailer / Email Service (SMTP)
EMAIL_HOST="smtp.mailtrap.io"
EMAIL_PORT=2525
EMAIL_USER="your_email_user"
EMAIL_PASS="your_email_password"
EMAIL_FROM="noreply@rishabh-provision-store.com"

# Twilio / SMS Service
TWILIO_ACCOUNT_SID="ACXXXXXXXXXXXXXXXX"
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_PHONE_NUMBER="+1234567890"
